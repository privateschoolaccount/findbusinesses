# Google Places API — https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Custom Search API — https://programmablesearchengine.google.com/
GOOGLE_CUSTOM_SEARCH_API_KEY=your_custom_search_api_key_here
GOOGLE_CUSTOM_SEARCH_CX=your_custom_search_engine_id_here

# Server port (default 3001)
PORT=3001

# SQLite database path (default ./data/findbusinesses.db)
DATABASE_PATH=
